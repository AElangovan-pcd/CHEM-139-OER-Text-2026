# LibreOffice / Word lock files
.~lock.*#

# Python build / cache
__pycache__/
*.pyc
*.pyo
.python-version

# Backup .docx files (large; reproducible from history if ever needed)
.firecrawl/backups/

# Generated HTML preview output (rebuildable from .docx via .firecrawl/build_html.py).
# HTML_Files/ stays tracked so reviewers can read it without running the build;
# the GitHub Pages CI regenerates it on every push to main.
# HTML_Files_Canvas/ is local-only build output tied to a specific Canvas course's
# import workflow, so it does not belong in the public remote.
HTML_Files_Canvas/
# HTML_Files/  # uncomment if you'd rather treat the standalone preview as a build artefact too

# Lean-remote policy (set 2026-04-29):
# The remote keeps only what the GitHub Pages CI needs. Everything under
# .firecrawl/ except build_html.py is local editorial scratch — rewrite scripts,
# OpenStax scrapes, JSON briefs, one-shot inserters. Untracking them here also
# prevents accidental re-adds via `git add .`.
#
# Extended 2026-05-05 to cover the variable-problem pilot: build_interactive.py
# and its tests, the engine source directory, and the YAML spec directory all
# need to track because GitHub Pages CI consumes them when building the
# /interactive/ subsite.
.firecrawl/*
!.firecrawl/build_html.py
!.firecrawl/build_interactive.py
!.firecrawl/test_build_interactive.py
!.firecrawl/interactive_engine/
!.firecrawl/interactive_engine/**
!.firecrawl/interactive_specs/
!.firecrawl/interactive_specs/**

# IMSCC bundle — regenerated by .firecrawl/build_imscc.py on demand
CHEM_139_OER.imscc

# Personal scratch notes (not part of the published OER)
CanvasInstructions_AE.txt

# Project conventions for LLM collaborators — backed up to ~/Documents/CLAUDE_MD_Files/CHEM_139/
CLAUDE.md

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
.claude/
*.swp
*~

# Local secrets (Canvas API tokens, etc.) — never commit
.env
.env.local
canvas_token*
*.token

# Downloaded source-material PDFs (reference only, not authored content;
# users can re-download from the original source if needed)
acs-periodic-table-poster_download.pdf

# Stray pre-rewrite docx left at .firecrawl root by an earlier scratch run
.firecrawl/Chapter_*.before-*.docx

# Backup SVGs created by .firecrawl/fix_svg_viewboxes.py before viewBox correction
Images/Chapter_*/embedded/*.before-viewbox-fix.svg
